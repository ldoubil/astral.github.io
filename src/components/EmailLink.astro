---
import Default from '@astrojs/starlight/components/SocialIcons.astro';
import AmlJumpDialog from './AmlJumpDialog.astro';
---

<a
	href="https://aml.astral.fan/"
	class="aml-invite"
	data-aml-invite
	aria-label="AML MC启动器测试邀请"
	title="前往 AML · MC启动器测试"
>
	<span class="aml-invite-mark" aria-hidden="true">
		<img src="/images/aml-logo.png" alt="" width="72" height="28" decoding="async" />
	</span>
	<span class="aml-invite-text">MC启动器测试邀请</span>
	<span class="aml-invite-arrow" aria-hidden="true">↗</span>
</a>

<span class="aml-invite-divider" aria-hidden="true"></span>

<Default><slot /></Default>
<AmlJumpDialog />

<style>
	.aml-invite {
		--aml-green: #3ddc84;
		--aml-green-deep: #1fa85a;
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		max-width: 100%;
		padding: 0.28rem 0.55rem 0.28rem 0.4rem;
		border-radius: 0.55rem;
		text-decoration: none;
		color: inherit;
		background: linear-gradient(
			120deg,
			color-mix(in srgb, var(--aml-green) 16%, transparent) 0%,
			color-mix(in srgb, var(--aml-green) 4%, transparent) 55%,
			transparent 100%
		);
		border: 1px solid color-mix(in srgb, var(--aml-green) 28%, transparent);
		box-shadow: inset 0 1px 0 color-mix(in srgb, white 8%, transparent);
		transition:
			transform 0.18s ease,
			border-color 0.18s ease,
			background 0.18s ease,
			box-shadow 0.18s ease;
	}

	.aml-invite:hover {
		transform: translateY(-1px);
		border-color: color-mix(in srgb, var(--aml-green) 55%, transparent);
		background: linear-gradient(
			120deg,
			color-mix(in srgb, var(--aml-green) 24%, transparent) 0%,
			color-mix(in srgb, var(--aml-green) 7%, transparent) 60%,
			transparent 100%
		);
		box-shadow:
			inset 0 1px 0 color-mix(in srgb, white 10%, transparent),
			0 6px 16px color-mix(in srgb, var(--aml-green) 16%, transparent);
	}

	.aml-invite:active {
		transform: translateY(0);
	}

	.aml-invite-mark {
		display: inline-flex;
		align-items: center;
		flex-shrink: 0;
	}

	.aml-invite-mark img {
		display: block;
		height: 1.35rem;
		width: auto;
		object-fit: contain;
	}

	.aml-invite-text {
		font-size: 0.78rem;
		font-weight: 600;
		color: var(--sl-color-gray-2);
		white-space: nowrap;
		line-height: 1.1;
	}

	.aml-invite:hover .aml-invite-text {
		color: var(--sl-color-white);
	}

	:global([data-theme='light']) .aml-invite:hover .aml-invite-text {
		color: var(--sl-color-gray-1);
	}

	.aml-invite-arrow {
		font-size: 0.72rem;
		font-weight: 700;
		opacity: 0.5;
		transform: translateY(-0.5px);
		transition:
			opacity 0.18s ease,
			transform 0.18s ease,
			color 0.18s ease;
	}

	.aml-invite:hover .aml-invite-arrow {
		opacity: 1;
		transform: translate(1px, -1.5px);
		color: var(--aml-green-deep);
	}

	:global([data-theme='dark']) .aml-invite:hover .aml-invite-arrow {
		color: var(--aml-green);
	}

	.aml-invite-divider {
		display: inline-block;
		width: 1px;
		height: 1.15rem;
		margin-inline: 0.15rem;
		background: var(--sl-color-gray-5);
		align-self: center;
		flex-shrink: 0;
	}

	@media (max-width: 50rem) {
		.aml-invite-text,
		.aml-invite-arrow {
			display: none;
		}

		.aml-invite {
			padding: 0.22rem;
		}
	}
</style>
