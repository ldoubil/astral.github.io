---
import previewDownloads from '../../public/preview-downloads.json';

const ALLOWED_IDS = ['game', 'universal'] as const;
const categories = previewDownloads.categories.filter((c) =>
  ALLOWED_IDS.includes(c.id as (typeof ALLOWED_IDS)[number])
);

type Category = (typeof categories)[number];
type Download = NonNullable<Category['downloads']>[number];

const editionMirror: Partial<Record<string, string>> = {
  game: '夸克网盘',
  universal: '夸克网盘',
};
---

<style>
  .preview-hub {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    margin: 2rem 0 1rem;
  }

  .edition {
    --edition-accent: #667eea;
    --edition-accent-soft: rgba(102, 126, 234, 0.12);
    --edition-accent-border: rgba(102, 126, 234, 0.28);
    border-radius: 20px;
    border: 1px solid var(--sl-color-hairline);
    background: var(--sl-color-bg-nav);
    overflow: hidden;
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.04);
    transition: box-shadow 0.25s ease, border-color 0.25s ease;
  }

  .edition:hover {
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.07);
    border-color: var(--edition-accent-border);
  }

  .edition.game {
    --edition-accent: #f97316;
    --edition-accent-soft: rgba(249, 115, 22, 0.1);
    --edition-accent-border: rgba(249, 115, 22, 0.35);
  }

  .edition.universal {
    --edition-accent: #0ea5e9;
    --edition-accent-soft: rgba(14, 165, 233, 0.1);
    --edition-accent-border: rgba(14, 165, 233, 0.35);
  }

  .edition-head {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.35rem 1.5rem;
    background: linear-gradient(
      135deg,
      var(--edition-accent-soft) 0%,
      transparent 55%
    );
    border-bottom: 1px solid var(--sl-color-hairline);
  }

  .edition-icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 14px;
    background: var(--edition-accent-soft);
    color: var(--edition-accent);
    border: 1px solid var(--edition-accent-border);
  }

  .edition-icon svg {
    width: 26px;
    height: 26px;
  }

  .edition-meta {
    flex: 1;
    min-width: 0;
  }

  .edition-meta h2 {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--sl-color-text);
    letter-spacing: -0.02em;
  }

  .edition-meta p {
    margin: 0.35rem 0 0;
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--sl-color-text-accent);
  }

  .status-badge {
    flex-shrink: 0;
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .status-badge.available {
    background: rgba(16, 185, 129, 0.12);
    color: #059669;
    border: 1px solid rgba(16, 185, 129, 0.25);
  }

  .status-badge.developing {
    background: rgba(245, 158, 11, 0.12);
    color: #d97706;
    border: 1px solid rgba(245, 158, 11, 0.25);
  }

  [data-theme='dark'] .status-badge.available {
    color: #34d399;
  }

  [data-theme='dark'] .status-badge.developing {
    color: #fbbf24;
  }

  .edition-body {
    padding: 0.25rem 0;
  }

  .mirror-bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1.5rem 0.5rem;
    font-size: 0.8rem;
    color: var(--sl-color-text-accent);
  }

  .mirror-bar svg {
    width: 16px;
    height: 16px;
    opacity: 0.7;
  }

  .release-list {
    list-style: none;
    margin: 0;
    padding: 0.5rem 1rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .release-item {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.15rem;
    border-radius: 14px;
    border: 1px solid var(--sl-color-hairline);
    background: var(--sl-color-bg);
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .release-item:hover {
    border-color: var(--edition-accent-border);
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
  }

  .release-item.is-latest {
    border-color: var(--edition-accent-border);
    background: linear-gradient(
      135deg,
      var(--edition-accent-soft) 0%,
      var(--sl-color-bg) 70%
    );
    box-shadow: inset 3px 0 0 var(--edition-accent);
  }

  .release-info {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    min-width: 0;
  }

  .release-top {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 0.75rem;
  }

  .release-version {
    font-family: ui-monospace, 'Cascadia Code', 'Segoe UI Mono', monospace;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--sl-color-text);
    word-break: break-all;
  }

  .release-badge {
    padding: 0.15rem 0.55rem;
    border-radius: 6px;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    background: var(--edition-accent);
    color: white;
  }

  .release-badge.build {
    background: var(--sl-color-gray-5);
    color: var(--sl-color-bg);
    text-transform: none;
    letter-spacing: 0;
    font-weight: 600;
  }

  .release-platforms {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .platform-pill {
    padding: 0.2rem 0.55rem;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--sl-color-text-accent);
    background: var(--sl-color-gray-6);
    border: 1px solid var(--sl-color-hairline);
  }

  [data-theme='dark'] .platform-pill {
    background: rgba(255, 255, 255, 0.06);
  }

  .release-dl {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    padding: 0.6rem 1.1rem;
    border-radius: 10px;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    color: white;
    background: linear-gradient(135deg, var(--edition-accent) 0%, color-mix(in srgb, var(--edition-accent) 75%, #1e1b4b) 100%);
    box-shadow: 0 2px 10px color-mix(in srgb, var(--edition-accent) 35%, transparent);
    transition: transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease;
  }

  .release-dl:hover {
    transform: translateY(-2px);
    filter: brightness(1.06);
    box-shadow: 0 6px 20px color-mix(in srgb, var(--edition-accent) 40%, transparent);
  }

  .release-dl svg {
    width: 18px;
    height: 18px;
  }

  .edition-empty {
    margin: 0.75rem 1.5rem 1.35rem;
    padding: 2.5rem 1.5rem;
    text-align: center;
    border-radius: 14px;
    border: 2px dashed var(--sl-color-hairline);
    background: repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 8px,
      var(--edition-accent-soft) 8px,
      var(--edition-accent-soft) 9px
    );
  }

  .edition-empty-icon {
    width: 44px;
    height: 44px;
    margin: 0 auto 1rem;
    color: var(--edition-accent);
    opacity: 0.65;
  }

  .edition-empty p {
    margin: 0;
    font-size: 0.95rem;
    color: var(--sl-color-text-accent);
  }

  .edition-empty strong {
    display: block;
    margin-bottom: 0.35rem;
    font-size: 1rem;
    color: var(--sl-color-text);
  }

  @media (max-width: 640px) {
    .edition-head {
      flex-wrap: wrap;
      padding: 1.15rem;
    }

    .status-badge {
      margin-left: calc(48px + 1rem);
    }

    .release-item {
      grid-template-columns: 1fr;
      gap: 0.85rem;
    }

    .release-dl {
      width: 100%;
    }

    .mirror-bar,
    .release-list {
      padding-left: 1.15rem;
      padding-right: 1.15rem;
    }
  }
</style>

<div class="preview-hub">
  {categories.map((category) => {
    const mirror = editionMirror[category.id];
    const releases = category.downloads ?? [];
    const hasReleases = releases.length > 0;
    const showDownloads = hasReleases;
    const badgeStatus = hasReleases ? 'available' : category.status;

    return (
      <article class={`edition ${category.id}`}>
        <header class="edition-head">
          <div class="edition-icon" aria-hidden="true">
            {category.id === 'game' ? (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14.25 9.75L16.5 12l2.25-2.25M9.75 14.25L7.5 12l2.25 2.25M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                <circle cx="8.5" cy="9.5" r="1.25" fill="currentColor" stroke="none" />
                <circle cx="15.5" cy="14.5" r="1.25" fill="currentColor" stroke="none" />
              </svg>
            ) : (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5" />
              </svg>
            )}
          </div>
          <div class="edition-meta">
            <h2>{category.name}</h2>
            <p>{category.description}</p>
          </div>
          <span class={`status-badge ${badgeStatus}`}>
            {badgeStatus === 'available' ? '可下载' : '开发中'}
          </span>
        </header>

        <div class="edition-body">
          {showDownloads ? (
            <>
              {mirror && (
                <div class="mirror-bar">
                  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96z"/>
                  </svg>
                  <span>通过 {mirror} 分发</span>
                </div>
              )}
              <ul class="release-list">
                {releases.map((download: Download, index: number) => (
                  <li class={`release-item ${index === 0 ? 'is-latest' : ''}`}>
                    <div class="release-info">
                      <div class="release-top">
                        <span class="release-version">{download.version}</span>
                        {index === 0 && <span class="release-badge">最新</span>}
                        {download.date && (
                          <span class="release-badge build">{download.date}</span>
                        )}
                      </div>
                      {download.platforms && download.platforms.length > 0 && (
                        <div class="release-platforms">
                          {download.platforms.map((platform) => (
                            <span class="platform-pill">{platform}</span>
                          ))}
                        </div>
                      )}
                    </div>
                    <a
                      href={download.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="release-dl"
                    >
                      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/>
                      </svg>
                      下载
                    </a>
                  </li>
                ))}
              </ul>
            </>
          ) : (
            <div class="edition-empty">
              <svg class="edition-empty-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <p>
                <strong>暂无可用版本</strong>
                该渠道正在开发中，发布后将在此列出所有可下载版本。
              </p>
            </div>
          )}
        </div>
      </article>
    );
  })}
</div>
